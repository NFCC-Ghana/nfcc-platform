# ============================================================
# NFCC Platform - Environment Variables Template
# ============================================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to git!

NFCC_ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

HOST=0.0.0.0
PORT=8000

MODEL_PATH=models/xgboost_flood_risk.joblib

API_KEY=replace_me_with_secure_key
JWT_SECRET_KEY=replace_me_with_secure_key

ENABLE_WHATSAPP=true
ENABLE_SMS=false
ENABLE_EMAIL=false

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_RECIPIENTS=whatsapp:+233XXXXXXXXX

ALERT_THRESHOLD_MODERATE=30
ALERT_THRESHOLD_HIGH=50
ALERT_THRESHOLD_CRITICAL=70
ALERT_THRESHOLD_EXTREME=85

ALERT_COOLDOWN_MINUTES=30

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
